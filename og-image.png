<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="630" viewBox="0 0 1200 630" role="img" aria-label="Rust for Windows — Install & Build Native Apps">
  <defs>
    <linearGradient id="bg" x1="0" x2="0" y1="0" y2="1">
      <stop offset="0%" stop-color="#0b0b0c"/>
      <stop offset="100%" stop-color="#070708"/>
    </linearGradient>
    <filter id="shadow" x="-20%" y="-20%" width="140%" height="140%">
      <feDropShadow dx="0" dy="3" stdDeviation="6" flood-color="#000" flood-opacity="0.4"/>
    </filter>
  </defs>
  <rect width="1200" height="630" fill="url(#bg)"/>

  <!-- Gear-like orange ring -->
  <g transform="translate(210,315)">
    <circle r="140" fill="none" stroke="#c24a13" stroke-width="20"/>
    <g fill="#c24a13">
      <rect x="-6" y="-180" width="12" height="32" rx="3"/>
      <rect x="-6" y="148" width="12" height="32" rx="3"/>
      <rect x="-180" y="-6" width="32" height="12" rx="3"/>
      <rect x="148" y="-6" width="32" height="12" rx="3"/>
      <g transform="rotate(30)"><rect x="-6" y="-180" width="12" height="32" rx="3"/></g>
      <g transform="rotate(60)"><rect x="-6" y="-180" width="12" height="32" rx="3"/></g>
      <g transform="rotate(120)"><rect x="-6" y="-180" width="12" height="32" rx="3"/></g>
      <g transform="rotate(150)"><rect x="-6" y="-180" width="12" height="32" rx="3"/></g>
      <g transform="rotate(210)"><rect x="-6" y="-180" width="12" height="32" rx="3"/></g>
      <g transform="rotate(240)"><rect x="-6" y="-180" width="12" height="32" rx="3"/></g>
      <g transform="rotate(300)"><rect x="-6" y="-180" width="12" height="32" rx="3"/></g>
      <g transform="rotate(330)"><rect x="-6" y="-180" width="12" height="32" rx="3"/></g>
    </g>
  </g>

  <!-- Monogram R -->
  <text x="210" y="345" text-anchor="middle" font-family="Segoe UI, Arial, sans-serif" font-size="180" font-weight="900" fill="#f5f5f5" filter="url(#shadow)">R</text>

  <!-- Headline -->
  <text x="420" y="250" font-family="Segoe UI, Arial, sans-serif" font-size="54" font-weight="900" fill="#f5f5f5">Rust for Windows</text>
  <rect x="420" y="265" width="330" height="6" rx="3" fill="#c24a13"/>
  <text x="420" y="330" font-family="Segoe UI, Arial, sans-serif" font-size="28" fill="#c9d1d9">Install & Build Native Apps — MSVC, windows-rs, Packaging</text>

  <!-- Download badge -->
  <g transform="translate(420,380)">
    <rect width="470" height="70" rx="14" fill="#c24a13"/>
    <text x="60" y="45" font-family="Segoe UI, Arial, sans-serif" font-size="28" font-weight="800" fill="#111">Download rustup-init.exe</text>
    <g transform="translate(18,18)" fill="#111">
      <rect x="14" y="0" width="10" height="28" rx="2"/>
      <path d="M14 0 h10 v12 h7 l-12 12 -12 -12 h7z"/>
    </g>
  </g>
</svg>
